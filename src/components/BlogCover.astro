---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Placeholder from './Placeholder.astro';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/blog/*.{jpg,jpeg,png}', {
  eager: true,
});

interface Props {
  name?: string;
  alt: string;
  ratio?: string;
  class?: string;
  rounded?: string;
  priority?: boolean;
  position?: string;
}

const {
  name,
  alt,
  ratio = '16/9',
  class: cls = '',
  rounded = 'rounded-none',
  priority = false,
  position = 'center',
} = Astro.props;

const entry = name ? images[`../assets/blog/${name}`] : undefined;
const img = entry?.default;
---

{
  img ? (
    <div class:list={['overflow-hidden border border-line', rounded, cls]} style={`aspect-ratio:${ratio}`}>
      <Image
        src={img}
        alt={alt}
        widths={[480, 800, 1200]}
        sizes="(max-width: 1024px) 100vw, 800px"
        class="h-full w-full object-cover"
        style={`object-position:${position}`}
        loading={priority ? 'eager' : 'lazy'}
      />
    </div>
  ) : (
    <Placeholder label="Blog-Cover" ratio={ratio} rounded={rounded} class={cls} />
  )
}
