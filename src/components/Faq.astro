---
import { Icon } from 'astro-icon/components';
interface Props {
  heading?: string;
  items: { q: string; a: string }[];
}
const { heading = 'Häufige Fragen', items } = Astro.props;

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a.replace(/<[^>]+>/g, '') },
  })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
<section class="container-page py-20">
  <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">{heading}</h2>
  <div class="mt-10 divide-y divide-line border-y border-line">
    {
      items.map((item) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-semibold text-ink">
            {item.q}
            <Icon name="lucide:plus" class="size-5 shrink-0 text-electric transition group-open:rotate-45" />
          </summary>
          <p class="mt-3 max-w-3xl text-body" set:html={item.a} />
        </details>
      ))
    }
  </div>
</section>
