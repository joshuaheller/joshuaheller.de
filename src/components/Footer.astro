---
import { Icon } from 'astro-icon/components';
import { SITE } from '../site';
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-surface-2">
  <div class="container-page grid gap-10 py-14 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <p class="text-lg font-extrabold tracking-tight text-ink">Joshua Heller</p>
      <p class="mt-3 max-w-xs text-sm text-muted">
        AI Engineer & Fractional CAIO. Vom Prototyp zum Produkt — direkt in deiner Codebase.
      </p>
      <a
        href={SITE.linkedin}
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-electric"
      >
        <Icon name="lucide:linkedin" class="size-4" /> LinkedIn
      </a>
    </div>

    <div>
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-muted">KI-Verständnis</p>
      <ul class="space-y-2 text-sm">
        <li><a href="/ki-workshop" class="text-body hover:text-electric">KI-Workshop</a></li>
        <li><a href="/ki-sparring" class="text-body hover:text-electric">KI-Sparring</a></li>
      </ul>
    </div>

    <div>
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-muted">Engineering & Führung</p>
      <ul class="space-y-2 text-sm">
        <li><a href="/forward-deployed-engineer" class="text-body hover:text-electric">Forward Deployed Engineer</a></li>
        <li><a href="/mvp" class="text-body hover:text-electric">MVP-Service</a></li>
        <li><a href="/fractional-caio" class="text-body hover:text-electric">Fractional CAIO</a></li>
      </ul>
    </div>

    <div>
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-muted">Mehr</p>
      <ul class="space-y-2 text-sm">
        <li><a href="/ueber-mich" class="text-body hover:text-electric">Über mich</a></li>
        <li><a href="/blog" class="text-body hover:text-electric">Blog</a></li>
        <li><a href="/ki-glossar" class="text-body hover:text-electric">KI-Glossar</a></li>
        <li><a href="/kontakt" class="text-body hover:text-electric">Kontakt</a></li>
        <li><a href="/impressum" class="text-body hover:text-electric">Impressum</a></li>
        <li><a href="/datenschutz" class="text-body hover:text-electric">Datenschutz</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-line">
    <div class="container-page flex flex-col gap-2 py-6 text-xs text-muted md:flex-row md:items-center md:justify-between">
      <p>
        Joshua Heller ist Geschäftsführer der
        <a href={SITE.taisc} target="_blank" rel="noopener" class="font-medium text-body hover:text-electric"
          >TAISC – The AI Software Company GmbH</a
        >.
      </p>
      <p>© {year} Joshua Heller · Logos der jeweiligen Markeninhaber.</p>
    </div>
  </div>
</footer>
