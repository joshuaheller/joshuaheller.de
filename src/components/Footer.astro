---
import { Icon } from 'astro-icon/components';
import { SITE } from '../site';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const { footer: f } = t;
---

<footer class="border-t border-line bg-surface-2">
  <div class="container-page grid gap-10 py-14 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <p class="text-lg font-extrabold tracking-tight text-ink">Joshua Heller</p>
      <p class="mt-3 max-w-xs text-sm text-muted">
        {f.tagline}
      </p>
      <a
        href={SITE.linkedin}
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-electric"
      >
        <Icon name="lucide:linkedin" class="size-4" /> LinkedIn
      </a>
    </div>

    <div>
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-muted">{f.col1}</p>
      <ul class="space-y-2 text-sm">
        <li><a href={f.links.workshop.href} class="text-body hover:text-electric">{f.links.workshop.label}</a></li>
        <li><a href={f.links.sparring.href} class="text-body hover:text-electric">{f.links.sparring.label}</a></li>
      </ul>
    </div>

    <div>
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-muted">{f.col2}</p>
      <ul class="space-y-2 text-sm">
        <li><a href={f.links.fde.href} class="text-body hover:text-electric">{f.links.fde.label}</a></li>
        <li><a href={f.links.mvp.href} class="text-body hover:text-electric">{f.links.mvp.label}</a></li>
        <li><a href={f.links.caio.href} class="text-body hover:text-electric">{f.links.caio.label}</a></li>
      </ul>
    </div>

    <div>
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-muted">{f.col3}</p>
      <ul class="space-y-2 text-sm">
        <li><a href={f.links.about.href} class="text-body hover:text-electric">{f.links.about.label}</a></li>
        <li><a href={f.links.blog.href} class="text-body hover:text-electric">{f.links.blog.label}</a></li>
        <li><a href={f.links.glossar.href} class="text-body hover:text-electric">{f.links.glossar.label}</a></li>
        <li><a href={f.links.contact.href} class="text-body hover:text-electric">{f.links.contact.label}</a></li>
        <li><a href={f.links.impressum.href} class="text-body hover:text-electric">{f.links.impressum.label}</a></li>
        <li><a href={f.links.datenschutz.href} class="text-body hover:text-electric">{f.links.datenschutz.label}</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-line">
    <div class="container-page flex flex-col gap-2 py-6 text-xs text-muted md:flex-row md:items-center md:justify-between">
      <p>
        {f.credit}{' '}
        <a href={SITE.taisc} target="_blank" rel="noopener" class="font-medium text-body hover:text-electric"
          >TAISC – The AI Software Company GmbH</a
        >.
      </p>
      <p>© {year} Joshua Heller · {f.logos}</p>
    </div>
  </div>
</footer>
