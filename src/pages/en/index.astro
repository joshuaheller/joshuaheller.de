---
import Layout from '../../layouts/Layout.astro';
import Photo from '../../components/Photo.astro';
import LogoWall from '../../components/LogoWall.astro';
import Stats from '../../components/Stats.astro';
import Steps from '../../components/Steps.astro';
import Faq from '../../components/Faq.astro';
import Cta from '../../components/Cta.astro';

const clusters = [
  {
    title: 'Build AI understanding',
    body: 'AI Workshop, AI strategy, and use-case discovery. You know AI matters — but don\'t know where to start.',
    href: '/en/ai-workshop',
    cta: 'Learn about AI Workshop',
  },
  {
    title: 'Build AI systems',
    body: 'Forward Deployed Engineer and MVP Service. You know what you want to build — you just need someone who actually delivers.',
    href: '/en/forward-deployed-engineer',
    cta: 'Learn about FDE',
  },
  {
    title: 'Lead AI strategy',
    body: 'Fractional CAIO and AI Sparring. You need part-time AI leadership without spending $200k+ a year on a full-time Chief AI Officer.',
    href: '/en/fractional-caio',
    cta: 'Learn about Fractional CAIO',
  },
];

const pains = [
  {
    title: 'Prototype works, product doesn\'t',
    body: 'You built a notebook, a ChatGPT integration, a RAG demo. It runs locally. But getting it to a live system is a mountain your team keeps getting stuck on.',
  },
  {
    title: 'Your team is strong, but not deep in AI',
    body: 'Frontend, backend, DevOps — all covered. But vector DBs, LangGraph, eval pipelines? That\'s where practice is missing. And hiring takes 6 months.',
  },
  {
    title: 'Architecture is a gut-feeling call',
    body: '"Should we use OpenAI or Anthropic?" "Do we need an agent or will a prompt chain do?" Nobody on the team can answer that from experience — so you\'re rolling the dice.',
  },
  {
    title: 'Your consultants deliver slide decks',
    body: 'You got a 100-page strategy document. Reading it takes a week. Implementing it takes 12 months. Lines of code written: 0.',
  },
  {
    title: 'Leadership is waiting for results',
    body: '"Where\'s our AI ROI?" — great question. But who on the tech team has the bandwidth to figure that out on the side? And who translates it for the C-suite?',
  },
  {
    title: 'A full-time CIO isn\'t in the budget',
    body: 'You need someone to own the AI strategy. But $200k+ a year for an experienced Chief AI Officer isn\'t justifiable — and it would take 9 months to find one.',
  },
];

const tabs = [
  { n: '01', name: 'Forward Deployed Engineer', head: 'I build inside your codebase', body: 'Weekly sprints or retainer. I become part of your team, build concrete AI features to production, document everything, and step back once your team can run independently.', price: 'from €200/h', href: '/en/forward-deployed-engineer' },
  { n: '02', name: 'MVP Service', head: 'From prototype to product in 2–6 weeks', body: 'Fixed price, fixed scope, a working MVP at the end. Validation with real users instead of a 6-month planning phase.', price: 'from €8,000', href: '/en/mvp' },
  { n: '03', name: 'Fractional CAIO', head: 'Part-time AI leadership', body: 'Strategic AI leadership 1–2 days per week as a retainer. Roadmap, architecture, vendor management. Like a Chief AI Officer — without the full-time salary.', price: 'from €3,000/month', href: '/en/fractional-caio' },
  { n: '04', name: 'AI Workshop', head: 'From buzzword to roadmap', body: '1- to 2-day workshop with your team. Use-case mapping, tool selection, concrete next steps as a deliverable.', price: 'from €3,000', href: '/en/ai-workshop' },
  { n: '05', name: 'AI Sparring', head: 'External sparring partner', body: 'An independent perspective for tech decision-makers — by the hour, when you need that outside view. No vendor lock-in.', price: 'from €300/h', href: '/en/ai-sparring' },
];

const principles = [
  { title: 'I tell you how it is.', body: 'If your use case doesn\'t need AI, I\'ll say so. If your tech stack plan is a mistake, I\'ll say that too. No buzzword bingo, no sugarcoated roadmaps.', sub: 'Honest assessment, even when it\'s uncomfortable.' },
  { title: 'I deliver code, not decks.', body: 'Every engagement ends with an artifact: a working MVP, an architecture doc, a piece of production code, a roadmap with tickets.', sub: 'Impact over slides.' },
  { title: 'I make myself obsolete.', body: 'My goal isn\'t to embed myself in your team. It\'s to enable you so thoroughly that you can move forward on your own. Knowledge transfer is part of every project.', sub: 'No lock-in, no knowledge hoarding.' },
  { title: 'I don\'t take kickbacks.', body: 'I recommend OpenAI, Anthropic, Azure, AWS, Lovable, n8n, Supabase — based on fit, not commissions.', sub: 'Objective evaluation, no sales pitches.' },
];

const steps = [
  { title: 'Intro call', body: '30–45 min video call. You explain what\'s stuck. I listen and ask questions. By the end, we both know if and how I can help.', meta: '⏱ 30–45 min · Clarity on fit' },
  { title: 'Discovery', body: 'I look at your setup: codebase, architecture, team, existing AI approaches. This produces an assessment — not a 100-page doc.', meta: '⏱ 1–2 weeks · Solid understanding' },
  { title: 'Proposal', body: 'You get a concrete proposal: hour bank for FDE, fixed price for MVP, retainer for Fractional CAIO. With scope, price, and delivery dates.', meta: '⏱ a few days · Written proposal' },
  { title: 'Execution', body: 'We start. Weekly calls, ongoing availability, code in your repo. I work with the tools you use — and I\'m part of your team for the duration.', meta: '⏱ depends on engagement · Code, MVP, Roadmap' },
];

const faqs = [
  { q: 'What does working together cost?', a: 'It depends on the model. Forward Deployed Engineer from €200/h net (from a minimum commitment, with discount as a retainer). AI Sparring for individual hours from €300/h. MVP fixed price from €8,000. Fractional CAIO as a retainer from €3,000/month. We\'ll nail down the exact terms in the intro call based on scope.' },
  { q: 'What industries and company sizes have you worked with?', a: 'Across the board: automotive and industrial (Daimler Trucks context, STIHL, WM aquatec), B2B SaaS and software (Onventis, Bitwerft, BCT, mimacom), education (i40), and family office / private equity environments. From solo startups to mid-market companies, scaleups, and large enterprises. Working with multiple clients in the same industry is an advantage — I bring patterns from comparable projects.' },
  { q: 'Are you an agency?', a: 'No. I\'m CEO of TAISC – The AI Software Company GmbH. TAISC has a small team of experienced engineers, but my personal FDE and Fractional CAIO engagements are done by me directly — not delegated.' },
  { q: 'How quickly can you start?', a: 'Typically 1–3 weeks after signing. For urgent needs, I often find a gap sooner.' },
  { q: 'Do you work remotely or on-site?', a: 'Primarily remote. For workshops, discovery phases, and critical project phases I can come on-site — based in Karlsruhe/Pforzheim, active throughout the DACH region and available internationally.' },
  { q: 'What if I don\'t know what I need yet?', a: 'That\'s exactly what the intro call is for. 30 minutes. No commitment. We figure out what makes sense. Sometimes it\'s a 1-day workshop, sometimes an MVP, sometimes nothing — and I\'ll refer you to someone who\'s a better fit.' },
];
---

<Layout
  title="Joshua Heller — AI Engineer & Fractional CAIO"
  description="Forward Deployed Engineer and Fractional CAIO for AI projects — mid-market, enterprises, scaleups, private equity. From prototype to production, directly in your codebase. From €200/h."
  path="/en/"
  lang="en"
  alternatePath="/"
>
  <!-- Hero -->
  <section class="bg-blobs">
    <div class="container-page grid items-center gap-12 py-16 md:py-24 lg:grid-cols-2">
      <div>
        <h1 class="text-4xl font-extrabold leading-[1.05] tracking-tight text-ink md:text-5xl lg:text-6xl">
          I take your AI from prototype to production.
        </h1>
        <p class="mt-6 max-w-xl text-lg text-body">
          I'm Joshua — AI Engineer, founder of TAISC, and working exclusively in AI for 3 years. As a
          <strong class="text-ink">Forward Deployed Engineer</strong> I build directly in your codebase. As
          <strong class="text-ink">Fractional CAIO</strong> I lead your AI strategy. No slide decks. Real systems.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/en/contact" class="btn btn-primary">Book a Call →</a>
          <a href="/en/services" class="btn btn-ghost">All Services</a>
        </div>
      </div>
      <Photo name="cafe.jpg" alt="Joshua Heller, AI Engineer and Fractional CAIO, at his laptop" ratio="4/3" priority />
    </div>
  </section>

  <!-- Logo wall -->
  <LogoWall lang="en" />

  <!-- Who I am -->
  <section class="container-page grid gap-12 py-20 lg:grid-cols-2 lg:items-center">
    <div>
      <p class="eyebrow mb-4">Who I am</p>
      <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">Who I am and what I do</h2>
      <div class="mt-6 space-y-4 text-body">
        <p>
          I hold a B.Sc. in Digital Enterprise Management, started as a developer at Daimler Trucks, was AI Engineer at generic.de, built my own SaaS in 2023
          (<a href="https://imagetocaption.ai" class="font-medium text-electric" target="_blank" rel="noopener">imagetocaption.ai</a>,
          350,000+ users, solo, no funding), and now run TAISC.
        </p>
        <p>
          I know both sides: enterprise software with compliance, legacy, and 10-year roadmaps — and solo SaaS where every day counts. That mix helps me quickly see where AI actually makes a difference in your project.
        </p>
        <p>
          My mission: <strong class="text-ink">making mid-market companies, enterprises, and software firms more competitive with AI.</strong> Not through buzzwords. Through code that runs.
        </p>
      </div>
      <a href="/en/about" class="btn btn-ghost mt-8">More about me</a>
    </div>
    <Photo name="event.jpg" alt="Joshua Heller speaking at an AI event" ratio="4/3" />
  </section>

  <!-- Service clusters -->
  <section class="container-page py-12">
    <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">My service areas</h2>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        clusters.map((c) => (
          <div class="card-line flex flex-col p-7">
            <h3 class="text-xl font-bold text-ink">{c.title}</h3>
            <p class="mt-3 flex-1 text-body">{c.body}</p>
            <a href={c.href} class="mt-6 inline-flex items-center gap-1 font-semibold text-electric">{c.cta} →</a>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Quote -->
  <section class="my-12 bg-ink py-20 text-white">
    <div class="container-page max-w-4xl text-center">
      <p class="text-2xl font-medium leading-snug md:text-3xl">
        "Most AI projects don't fail because of the technology. They fail because of the distance between the people writing the strategy and the people writing the code. I close that gap — because I do both."
      </p>
      <p class="mt-6 text-sm text-white/60">— Joshua Heller</p>
    </div>
  </section>

  <!-- Stats -->
  <Stats lang="en" />

  <!-- Pain points -->
  <section class="bg-surface-2 py-20">
    <div class="container-page">
      <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">Does this sound familiar?</h2>
      <p class="mt-4 max-w-2xl text-body">
        Most teams I talk to face similar challenges. Not because they work poorly — but because AI is a new discipline where the rules are still being written.
      </p>
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          pains.map((p) => (
            <div class="card-line p-6">
              <h3 class="font-bold text-ink">{p.title}</h3>
              <p class="mt-2 text-sm text-body">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Service tabs -->
  <section class="container-page py-20">
    <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">How can I help?</h2>
    <div class="mt-10 grid gap-8 lg:grid-cols-[18rem_1fr]" id="svc-tabs">
      <div class="flex flex-col gap-2" role="tablist">
        {
          tabs.map((t, i) => (
            <button
              class="svc-tab flex items-center gap-3 rounded-2xl border border-line bg-white px-4 py-3 text-left text-sm font-semibold text-ink transition aria-selected:border-electric aria-selected:bg-surface-2"
              data-tab={i}
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              <span class="text-electric">{t.n}</span> {t.name}
            </button>
          ))
        }
      </div>
      <div>
        {
          tabs.map((t, i) => (
            <div class="svc-panel card-glass flex-col gap-4 p-8" data-panel={i} style={i === 0 ? '' : 'display:none'}>
              <h3 class="text-2xl font-bold text-ink">{t.head}</h3>
              <p class="mt-3 text-body">{t.body}</p>
              <div class="mt-6 flex flex-wrap items-center gap-4">
                <span class="pill">{t.price}</span>
                <a href={t.href} class="font-semibold text-electric">Learn more →</a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="bg-surface-2 py-20">
    <div class="container-page">
      <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">My principles</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          principles.map((p, i) => (
            <div class="card-line p-7">
              <span class="text-sm font-bold text-electric">0{i + 1}</span>
              <h3 class="mt-2 text-xl font-bold text-ink">{p.title}</h3>
              <p class="mt-2 text-body">{p.body}</p>
              <p class="mt-3 text-sm font-medium text-muted">{p.sub}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Steps -->
  <Steps heading="How we work together" steps={steps} />

  <!-- How I work -->
  <section class="container-page grid gap-12 py-20 lg:grid-cols-2">
    <div>
      <p class="eyebrow mb-4">How I work</p>
      <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">
        Software companies need someone who asks the right questions.
      </h2>
      <blockquote class="mt-8 border-l-2 border-electric pl-5 text-xl font-medium text-ink">
        "The best AI is the one your team understands and can operate."
        <footer class="mt-2 text-sm font-normal text-muted">— Joshua Heller</footer>
      </blockquote>
    </div>
    <div class="space-y-5 text-body">
      <p>
        "Should I use Claude Opus 4.7, an OpenAI model, or Gemini?" "Do I actually need RAG, or will the context window handle it?" "Local LLM — yes or no?" These are the questions I help with.
      </p>
      <p>
        My daily stack: Claude Code and Claude Cowork, CLI-first, LangChain and LangGraph for agentic workflows — deployable on Azure, AWS, Supabase, or Google Cloud. I work with whatever fits your setup.
      </p>
      <p>
        I don't take commissions. If I recommend Anthropic, it's because it fits. If I say you don't need AI for a use case, I mean it.
      </p>
      <h3 class="pt-2 text-lg font-bold text-ink">What sets me apart from an agency</h3>
      <p>
        An agency lives on billable hours — many clients, many tickets. I work intensively with a small number of clients. That's a different model — and it fits AI better than the agency model. My goal is to make myself redundant.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <Faq heading="Frequently Asked Questions" items={faqs} />

  <!-- CTA -->
  <Cta
    heading="Ready to take your AI to production?"
    sub="30 minutes. You explain what's going on. I tell you if and how I can help. No commitment."
    lang="en"
  />
</Layout>

<script>
  const root = document.getElementById('svc-tabs');
  if (root) {
    const tabs = root.querySelectorAll<HTMLButtonElement>('.svc-tab');
    const panels = root.querySelectorAll<HTMLElement>('.svc-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const idx = tab.dataset.tab;
        tabs.forEach((t) => t.setAttribute('aria-selected', String(t === tab)));
        panels.forEach((p) => (p.style.display = p.dataset.panel === idx ? 'flex' : 'none'));
      });
    });
  }
</script>
