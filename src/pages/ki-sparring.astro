---
import Layout from '../layouts/Layout.astro';
import ServiceHero from '../components/ServiceHero.astro';
import Cta from '../components/Cta.astro';
import { SITE } from '../site';

const when = [
  'Du bist Tech-Lead oder Founder und stehst regelmäßig vor KI-Entscheidungen — aber dein Team ist zu deep im Tagesgeschäft für Außensicht',
  'Du planst keine 12-Monats-Implementierung, sondern brauchst alle 1–2 Wochen einen Sparring-Termin',
  'Du willst eine Sekundärmeinung zu deiner Architektur-, Tool- oder Vendor-Wahl',
  'Du hast eine wichtige Tech-Entscheidung, die du jemandem präsentieren willst, der nicht in deinem Team ist und ehrlich antwortet',
];

const included = [
  'Ein- oder mehrstündige Sparring-Calls, planbar terminiert',
  'Eine ehrliche Sekundärmeinung zu Architektur, Tool- und Vendor-Wahl',
  'Code- und Architektur-Reviews im vereinbarten Rahmen',
  'Vorbereitete Empfehlungen zu konkreten Fragen (kein 50-Seiten-Doc — Bullets mit Begründung)',
  'Kein Implementierungs-Anteil. Wenn ihr Code braucht, ist das der Forward Deployed Engineer.',
];

const serviceLd = {
  '@context': 'https://schema.org', '@type': 'Service', name: 'KI-Sparring',
  serviceType: 'Advisory', provider: { '@type': 'Person', name: 'Joshua Heller', url: SITE.url }, areaServed: 'DACH',
  offers: {
    '@type': 'Offer', price: '300', priceCurrency: 'EUR',
    priceSpecification: { '@type': 'UnitPriceSpecification', price: '300', priceCurrency: 'EUR', unitText: 'HUR' },
  },
};
---

<Layout
  title="KI-Sparring: Dein externer Sparringspartner für Tech-Entscheidungen"
  description="Ein unabhängiger KI-Kopf für Tech-Entscheider — für einzelne Stunden, wenn du den fehlenden Außenblick brauchst. Ab 300 €/h, kein Vendor-Lock-in."
  path="/ki-sparring"
  lang="de"
  alternatePath="/en/ai-sparring"
  jsonLd={[serviceLd]}
>
  <ServiceHero
    eyebrow="KI-Sparring"
    title="Ein Kopf, der mitdenkt — wenn du ihn brauchst."
    sub="Kein Implementierungs-Engagement, keine Roadmap-Verantwortung. Einfach ein erfahrener KI-Engineer, der dir bei kniffligen Entscheidungen den fehlenden Außenblick gibt — buchbar pro Stunde."
    primary={{ label: 'Sparring anfragen →', href: '/kontakt' }}
    image="Joshua im Videocall / Sparring"
    photo="cafe.jpg"
    price="ab 300 €/h"
  />

  <section class="container-page py-20">
    <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">Wann KI-Sparring Sinn ergibt</h2>
    <ul class="mt-8 grid gap-4 md:grid-cols-2">
      {when.map((w) => <li class="card-line p-6 text-body">{w}</li>)}
    </ul>
  </section>

  <section class="bg-surface-2 py-20">
    <div class="container-page grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">Was enthalten ist</h2>
      </div>
      <ul class="space-y-3">
        {included.map((i) => <li class="rounded-xl border border-line bg-white p-4 text-sm text-body">{i}</li>)}
      </ul>
    </div>
  </section>

  <section class="container-page py-20">
    <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">Preis</h2>
    <div class="mt-10 grid gap-6 lg:grid-cols-[1fr_1.4fr]">
      <div class="card-line flex flex-col justify-center p-8">
        <p class="text-4xl font-extrabold text-electric">ab 300 €/h</p>
        <p class="mt-2 text-sm text-muted">netto, für einzelne Sparring-Stunden</p>
      </div>
      <div class="card-line p-8 text-body">
        <p>
          KI-Sparring rechne ich einfach nach Stunden ab — keine festen Pakete, keine monatliche Bindung. Du buchst genau
          so viel, wie du brauchst.
        </p>
        <p class="mt-3">
          Brauchst du regelmäßig größere Stundenkontingente oder echte Umsetzung in deiner Codebase, ist der
          <a href="/forward-deployed-engineer" class="font-medium text-electric">Forward Deployed Engineer</a> (ab 200 €/h
          ab einem Mindestumfang) der günstigere und passendere Weg.
        </p>
      </div>
    </div>
  </section>

  <Cta heading="Brauchst du einen Kopf, der mitdenkt?" sub="Sparring anfragen — unkompliziert, abgerechnet nach Stunden." lang="de" />
</Layout>
